{
  "name": "setup-fortran",
  "version": "1.3.0",
  "description": "Set up Fortran compilers on GitHub Actions runners",
  "homepage": "https://github.com/minhqdao/setup-fortran#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhqdao/setup-fortran.git"
  },
  "bugs": {
    "url": "https://github.com/minhqdao/setup-fortran/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Minh Dao",
    "email": "hello@minhdao.de",
    "url": "https://minhdao.de"
  },
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map",
    "build:integration-test": "ncc build src/run_fortran_tests.ts -o dist-tests --source-map",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "integration-test": "node dist-tests/index.js",
    "all": "npm run format && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/cache": "^5.1.0",
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/tool-cache": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
